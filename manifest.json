{
  "manifest_version": 3,
  "name": "Bug Hunter",
  "version": "1.0.0",
  "description": "Hunt and squash bugs crawling on real web pages. A fun stress-relief game to chase high scores.",
  "permissions": ["activeTab", "scripting", "clipboardWrite", "storage"],
  "background": {
    "service_worker": "dist/background/main.js"
  },
  "action": {
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "Bug Hunter",
    "default_popup": "dist/index.html"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
